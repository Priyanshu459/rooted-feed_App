<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="online.rooted_feed">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Rooted Feed"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RootedFeed.Splash">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask"> <!-- singleTask helps with intent handling -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep Linking for rooted-feed.online -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="www.rooted-feed.online" />
                <data android:scheme="https" android:host="rooted-feed.online" />
            </intent-filter>
        </activity>

        <activity
            android:name=".chat.ConversationActivity"
            android:exported="false"
            android:label="Messages"
            android:theme="@style/Theme.RootedFeed" />

        <activity
            android:name=".chat.ChatActivity"
            android:exported="false"
            android:label="Chat"
            android:theme="@style/Theme.RootedFeed" />
        
    </application>

</manifest>
