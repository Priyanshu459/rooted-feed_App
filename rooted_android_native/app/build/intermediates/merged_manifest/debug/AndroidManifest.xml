<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="online.rooted_feed"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="33" />

    <uses-permission android:name="android.permission.INTERNET" />

    <permission
        android:name="online.rooted_feed.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="online.rooted_feed.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Rooted Feed"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.RootedFeed.Splash" >
        <activity
            android:name="online.rooted_feed.MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true"
            android:launchMode="singleTask" > <!-- singleTask helps with intent handling -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep Linking for rooted-feed.online -->
            <intent-filter android:autoVerify="true" >
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="www.rooted-feed.online"
                    android:scheme="https" />
                <data
                    android:host="rooted-feed.online"
                    android:scheme="https" />
            </intent-filter>
        </activity>
        <activity
            android:name="online.rooted_feed.chat.ConversationActivity"
            android:exported="false"
            android:label="Messages"
            android:theme="@style/Theme.RootedFeed" />
        <activity
            android:name="online.rooted_feed.chat.ChatActivity"
            android:exported="false"
            android:label="Chat"
            android:theme="@style/Theme.RootedFeed" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="online.rooted_feed.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>